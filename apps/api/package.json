{
  "name": "@gov-dashboard/api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --noEmit -p seed/tsconfig.json",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply gov-dashboard --local",
    "db:generate-seed": "tsx seed/seed.ts",
    "db:seed:local": "npm run db:generate-seed && wrangler d1 execute gov-dashboard --local --file ./seed/output/seed.sql"
  },
  "dependencies": {
    "@gov-dashboard/shared-types": "*",
    "hono": "4.12.27",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@cloudflare/workers-types": "4.20260702.1",
    "typescript": "6.0.3",
    "wrangler": "4.106.0",
    "vitest": "4.1.9",
    "tsx": "4.22.4"
  }
}
